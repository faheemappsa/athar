[
    {
        "id": 1,
        "text": "بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ",
        "surah": "الفاتحة",
        "ayah": 1,
        "category": "آية",
        "tags": ["بسملة", "رحمة"]
    },
    {
        "id": 2,
        "text": "الْحَمْدُ لِلَّهِ رَبِّ الْعَالَمِينَ",
        "surah": "الفاتحة",
        "ayah": 2,
        "category": "آية",
        "tags": ["حمد", "ثناء"]
    },
    {
        "id": 3,
        "text": "الرَّحْمَٰنِ الرَّحِيمِ",
        "surah": "الفاتحة",
        "ayah": 3,
        "category": "آية",
        "tags": ["رحمة"]
    },
    {
        "id": 4,
        "text": "مَالِكِ يَوْمِ الدِّينِ",
        "surah": "الفاتحة",
        "ayah": 4,
        "category": "آية",
        "tags": ["يوم القيامة"]
    },
    {
        "id": 5,
        "text": "إِيَّاكَ نَعْبُدُ وَإِيَّاكَ نَسْتَعِينُ",
        "surah": "الفاتحة",
        "ayah": 5,
        "category": "آية",
        "tags": ["عبادة", "استعانة"]
    },
    {
        "id": 6,
        "text": "اهْدِنَا الصِّرَاطَ الْمُسْتَقِيمَ",
        "surah": "الفاتحة",
        "ayah": 6,
        "category": "آية",
        "tags": ["هداية"]
    },
    {
        "id": 7,
        "text": "صِرَاطَ الَّذِينَ أَنْعَمْتَ عَلَيْهِمْ غَيْرِ الْمَغْضُوبِ عَلَيْهِمْ وَلَا الضَّالِّينَ",
        "surah": "الفاتحة",
        "ayah": 7,
        "category": "آية",
        "tags": ["هداية", "نعمة"]
    },
    {
        "id": 8,
        "text": "وَإِلَٰهُكُمْ إِلَٰهٌ وَاحِدٌ ۖ لَّا إِلَٰهَ إِلَّا هُوَ الرَّحْمَٰنُ الرَّحِيمُ",
        "surah": "البقرة",
        "ayah": 163,
        "category": "آية",
        "tags": ["توحيد", "رحمة"]
    },
    {
        "id": 9,
        "text": "إِنَّ اللَّهَ مَعَ الصَّابِرِينَ",
        "surah": "البقرة",
        "ayah": 153,
        "category": "آية",
        "tags": ["صبر", "معية الله"]
    },
    {
        "id": 10,
        "text": "فَاذْكُرُونِي أَذْكُرْكُمْ وَاشْكُرُوا لِي وَلَا تَكْفُرُونِ",
        "surah": "البقرة",
        "ayah": 152,
        "category": "آية",
        "tags": ["ذكر", "شكر"]
    },
    {
        "id": 11,
        "text": "رَبَّنَا آتِنَا فِي الدُّنْيَا حَسَنَةً وَفِي الْآخِرَةِ حَسَنَةً وَقِنَا عَذَابَ النَّارِ",
        "surah": "البقرة",
        "ayah": 201,
        "category": "آية",
        "tags": ["دعاء", "حسنة"]
    },
    {
        "id": 12,
        "text": "اللَّهُ لَا إِلَٰهَ إِلَّا هُوَ الْحَيُّ الْقَيُّومُ ۚ لَا تَأْخُذُهُ سِنَةٌ وَلَا نَوْمٌ",
        "surah": "البقرة",
        "ayah": 255,
        "category": "آية",
        "tags": ["آية الكرسي", "توحيد", "عظمة"]
    },
    {
        "id": 13,
        "text": "لَا إِكْرَاهَ فِي الدِّينِ ۖ قَد تَّبَيَّنَ الرُّشْدُ مِنَ الْغَيِّ",
        "surah": "البقرة",
        "ayah": 256,
        "category": "آية",
        "tags": ["حرية", "هداية"]
    },
    {
        "id": 14,
        "text": "وَمَن يَتَوَكَّلْ عَلَى اللَّهِ فَهُوَ حَسْبُهُ",
        "surah": "الطلاق",
        "ayah": 3,
        "category": "آية",
        "tags": ["توكل", "كفاية"]
    },
    {
        "id": 15,
        "text": "إِنَّ اللَّهَ يُحِبُّ التَّوَّابِينَ وَيُحِبُّ الْمُتَطَهِّرِينَ",
        "surah": "البقرة",
        "ayah": 222,
        "category": "آية",
        "tags": ["توبة", "طهارة", "محبة"]
    },
    {
        "id": 16,
        "text": "وَقَالَ رَبُّكُمُ ادْعُونِي أَسْتَجِبْ لَكُمْ",
        "surah": "غافر",
        "ayah": 60,
        "category": "آية",
        "tags": ["دعاء", "استجابة"]
    },
    {
        "id": 17,
        "text": "أَلَا بِذِكْرِ اللَّهِ تَطْمَئِنُّ الْقُلُوبُ",
        "surah": "الرعد",
        "ayah": 28,
        "category": "آية",
        "tags": ["ذكر", "طمأنينة"]
    },
    {
        "id": 18,
        "text": "فَإِنَّ مَعَ الْعُسْرِ يُسْرًا . إِنَّ مَعَ الْعُسْرِ يُسْرًا",
        "surah": "الشرح",
        "ayah": "5-6",
        "category": "آية",
        "tags": ["فرج", "يسر", "أمل"]
    },
    {
        "id": 19,
        "text": "وَمَا أَرْسَلْنَاكَ إِلَّا رَحْمَةً لِّلْعَالَمِينَ",
        "surah": "الأنبياء",
        "ayah": 107,
        "category": "آية",
        "tags": ["رحمة", "نبي"]
    },
    {
        "id": 20,
        "text": "إِنَّ اللَّهَ وَمَلَائِكَتَهُ يُصَلُّونَ عَلَى النَّبِيِّ ۚ يَا أَيُّهَا الَّذِينَ آمَنُوا صَلُّوا عَلَيْهِ وَسَلِّمُوا تَسْلِيمًا",
        "surah": "الأحزاب",
        "ayah": 56,
        "category": "آية",
        "tags": ["صلاة على النبي", "أمر إلهي"]
    },
    {
        "id": 21,
        "text": "قُلْ هُوَ اللَّهُ أَحَدٌ . اللَّهُ الصَّمَدُ . لَمْ يَلِدْ وَلَمْ يُولَدْ . وَلَمْ يَكُن لَّهُ كُفُوًا أَحَدٌ",
        "surah": "الإخلاص",
        "ayah": "1-4",
        "category": "آية",
        "tags": ["توحيد", "إخلاص"]
    },
    {
        "id": 22,
        "text": "قُلْ أَعُوذُ بِرَبِّ الْفَلَقِ . مِن شَرِّ مَا خَلَقَ",
        "surah": "الفلق",
        "ayah": "1-2",
        "category": "آية",
        "tags": ["معوذة", "استعاذة"]
    },
    {
        "id": 23,
        "text": "قُلْ أَعُوذُ بِرَبِّ النَّاسِ . مَلِكِ النَّاسِ . إِلَٰهِ النَّاسِ",
        "surah": "الناس",
        "ayah": "1-3",
        "category": "آية",
        "tags": ["معوذة", "استعاذة"]
    },
    {
        "id": 24,
        "text": "وَمَا تَوْفِيقِي إِلَّا بِاللَّهِ ۚ عَلَيْهِ تَوَكَّلْتُ وَإِلَيْهِ أُنِيبُ",
        "surah": "هود",
        "ayah": 88,
        "category": "آية",
        "tags": ["توفيق", "توكل"]
    },
    {
        "id": 25,
        "text": "وَاسْتَعِينُوا بِالصَّبْرِ وَالصَّلَاةِ",
        "surah": "البقرة",
        "ayah": 45,
        "category": "آية",
        "tags": ["صبر", "صلاة", "استعانة"]
    },
    {
        "id": 26,
        "text": "رَبِّ اشْرَحْ لِي صَدْرِي . وَيَسِّرْ لِي أَمْرِي",
        "surah": "طه",
        "ayah": "25-26",
        "category": "آية",
        "tags": ["دعاء", "شرح صدر", "تيسير"]
    },
    {
        "id": 27,
        "text": "رَبَّنَا لَا تُؤَاخِذْنَا إِن نَّسِينَا أَوْ أَخْطَأْنَا",
        "surah": "البقرة",
        "ayah": 286,
        "category": "آية",
        "tags": ["دعاء", "مغفرة", "رحمة"]
    },
    {
        "id": 28,
        "text": "رَبَّنَا أَفْرِغْ عَلَيْنَا صَبْرًا وَثَبِّتْ أَقْدَامَنَا",
        "surah": "البقرة",
        "ayah": 250,
        "category": "آية",
        "tags": ["دعاء", "ثبات", "صبر"]
    },
    {
        "id": 29,
        "text": "وَلَا تَحْسَبَنَّ اللَّهَ غَافِلًا عَمَّا يَعْمَلُ الظَّالِمُونَ",
        "surah": "إبراهيم",
        "ayah": 42,
        "category": "آية",
        "tags": ["عدل", "ظلم"]
    },
    {
        "id": 30,
        "text": "وَبَشِّرِ الصَّابِرِينَ",
        "surah": "البقرة",
        "ayah": 155,
        "category": "آية",
        "tags": ["بشرى", "صبر"]
    }
]
