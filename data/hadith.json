[
    {
        "id": 1,
        "text": "إنما الأعمال بالنيات، وإنما لكل امرئ ما نوى",
        "ref": "متفق عليه",
        "source": "البخاري ومسلم",
        "book": "صحيح البخاري",
        "hadith_number": 1,
        "category": "حديث",
        "tags": ["نية", "إخلاص", "أعمال"]
    },
    {
        "id": 2,
        "text": "إذا مات الإنسان انقطع عنه عمله إلا من ثلاث: إلا من صدقة جارية، أو علم ينتفع به، أو ولد صالح يدعو له",
        "ref": "رواه مسلم",
        "source": "مسلم",
        "book": "صحيح مسلم",
        "hadith_number": 1631,
        "category": "حديث",
        "tags": ["صدقة جارية", "علم", "ولد صالح"]
    },
    {
        "id": 3,
        "text": "الكلمة الطيبة صدقة",
        "ref": "متفق عليه",
        "source": "البخاري ومسلم",
        "book": "صحيح البخاري",
        "hadith_number": 2989,
        "category": "حديث",
        "tags": ["صدقة", "كلمة طيبة"]
    },
    {
        "id": 4,
        "text": "تبسمك في وجه أخيك لك صدقة",
        "ref": "رواه الترمذي",
        "source": "الترمذي",
        "book": "سنن الترمذي",
        "hadith_number": 1956,
        "category": "حديث",
        "tags": ["صدقة", "ابتسامة", "أخلاق"]
    },
    {
        "id": 5,
        "text": "مثل المؤمنين في توادهم وتراحمهم وتعاطفهم مثل الجسد إذا اشتكى منه عضو تداعى له سائر الجسد بالسهر والحمى",
        "ref": "متفق عليه",
        "source": "البخاري ومسلم",
        "book": "صحيح مسلم",
        "hadith_number": 2586,
        "category": "حديث",
        "tags": ["تراحم", "مؤمنين", "وحدة"]
    },
    {
        "id": 6,
        "text": "لا يؤمن أحدكم حتى يحب لأخيه ما يحب لنفسه",
        "ref": "متفق عليه",
        "source": "البخاري ومسلم",
        "book": "صحيح البخاري",
        "hadith_number": 13,
        "category": "حديث",
        "tags": ["إيمان", "محبة", "إيثار"]
    },
    {
        "id": 7,
        "text": "من كان يؤمن بالله واليوم الآخر فليقل خيراً أو ليصمت",
        "ref": "متفق عليه",
        "source": "البخاري ومسلم",
        "book": "صحيح البخاري",
        "hadith_number": 6018,
        "category": "حديث",
        "tags": ["صمت", "خير", "إيمان"]
    },
    {
        "id": 8,
        "text": "الدال على الخير كفاعله",
        "ref": "رواه الترمذي",
        "source": "الترمذي",
        "book": "سنن الترمذي",
        "hadith_number": 2670,
        "category": "حديث",
        "tags": ["خير", "دعوة", "أجر"]
    },
    {
        "id": 9,
        "text": "خيركم من تعلم القرآن وعلمه",
        "ref": "رواه البخاري",
        "source": "البخاري",
        "book": "صحيح البخاري",
        "hadith_number": 5027,
        "category": "حديث",
        "tags": ["قرآن", "تعليم", "خيرية"]
    },
    {
        "id": 10,
        "text": "إن الله لا ينظر إلى صوركم وأموالكم ولكن ينظر إلى قلوبكم وأعمالكم",
        "ref": "رواه مسلم",
        "source": "مسلم",
        "book": "صحيح مسلم",
        "hadith_number": 2564,
        "category": "حديث",
        "tags": ["قلب", "عمل", "إخلاص"]
    },
    {
        "id": 11,
        "text": "المسلم من سلم المسلمون من لسانه ويده",
        "ref": "متفق عليه",
        "source": "البخاري ومسلم",
        "book": "صحيح البخاري",
        "hadith_number": 10,
        "category": "حديث",
        "tags": ["سلامة", "لسان", "يد"]
    },
    {
        "id": 12,
        "text": "من حسن إسلام المرء تركه ما لا يعنيه",
        "ref": "رواه الترمذي",
        "source": "الترمذي",
        "book": "سنن الترمذي",
        "hadith_number": 2317,
        "category": "حديث",
        "tags": ["حسن", "إسلام", "ترك"]
    },
    {
        "id": 13,
        "text": "أحب الأعمال إلى الله أدومها وإن قل",
        "ref": "متفق عليه",
        "source": "البخاري ومسلم",
        "book": "صحيح مسلم",
        "hadith_number": 782,
        "category": "حديث",
        "tags": ["دوام", "عمل", "قليل"]
    },
    {
        "id": 14,
        "text": "كلمتان حبيبتان إلى الرحمن، خفيفتان على اللسان، ثقيلتان في الميزان: سبحان الله وبحمده، سبحان الله العظيم",
        "ref": "متفق عليه",
        "source": "البخاري ومسلم",
        "book": "صحيح البخاري",
        "hadith_number": 6682,
        "category": "حديث",
        "tags": ["ذكر", "تسبيح", "ميزان"]
    },
    {
        "id": 15,
        "text": "من سلك طريقاً يلتمس فيه علماً سهل الله له طريقاً إلى الجنة",
        "ref": "رواه مسلم",
        "source": "مسلم",
        "book": "صحيح مسلم",
        "hadith_number": 2699,
        "category": "حديث",
        "tags": ["علم", "طريق", "جنة"]
    },
    {
        "id": 16,
        "text": "إن من أحبكم إلي وأقربكم مني مجلساً يوم القيامة أحاسنكم أخلاقاً",
        "ref": "رواه الترمذي",
        "source": "الترمذي",
        "book": "سنن الترمذي",
        "hadith_number": 2018,
        "category": "حديث",
        "tags": ["أخلاق", "قرب", "قيامة"]
    },
    {
        "id": 17,
        "text": "اتق الله حيثما كنت، وأتبع السيئة الحسنة تمحها، وخالق الناس بخلق حسن",
        "ref": "رواه الترمذي",
        "source": "الترمذي",
        "book": "سنن الترمذي",
        "hadith_number": 1987,
        "category": "حديث",
        "tags": ["تقوى", "حسنة", "خلق"]
    },
    {
        "id": 18,
        "text": "اللهم إني أسألك الهدى والتقى والعفاف والغنى",
        "ref": "رواه مسلم",
        "source": "مسلم",
        "book": "صحيح مسلم",
        "hadith_number": 2721,
        "category": "حديث",
        "tags": ["دعاء", "هدى", "عفاف"]
    },
    {
        "id": 19,
        "text": "من صلى علي صلاة صلى الله عليه بها عشراً",
        "ref": "رواه مسلم",
        "source": "مسلم",
        "book": "صحيح مسلم",
        "hadith_number": 408,
        "category": "حديث",
        "tags": ["صلاة على النبي", "أجر", "عشرة"]
    },
    {
        "id": 20,
        "text": "ما نقصت صدقة من مال",
        "ref": "رواه مسلم",
        "source": "مسلم",
        "book": "صحيح مسلم",
        "hadith_number": 2588,
        "category": "حديث",
        "tags": ["صدقة", "مال", "بركة"]
    },
    {
        "id": 21,
        "text": "خير الأصحاب عند الله خيرهم لصاحبه، وخير الجيران عند الله خيرهم لجاره",
        "ref": "رواه الترمذي",
        "source": "الترمذي",
        "book": "سنن الترمذي",
        "hadith_number": 1944,
        "category": "حديث",
        "tags": ["صحبة", "جوار", "خير"]
    },
    {
        "id": 22,
        "text": "ليس الشديد بالصرعة، إنما الشديد الذي يملك نفسه عند الغضب",
        "ref": "متفق عليه",
        "source": "البخاري ومسلم",
        "book": "صحيح البخاري",
        "hadith_number": 6114,
        "category": "حديث",
        "tags": ["غضب", "قوة", "نفس"]
    },
    {
        "id": 23,
        "text": "من توضأ فأحسن الوضوء خرجت خطاياه من جسده حتى تخرج من تحت أظفاره",
        "ref": "رواه مسلم",
        "source": "مسلم",
        "book": "صحيح مسلم",
        "hadith_number": 245,
        "category": "حديث",
        "tags": ["وضوء", "خطايا", "طهارة"]
    },
    {
        "id": 24,
        "text": "الطهور شطر الإيمان",
        "ref": "رواه مسلم",
        "source": "مسلم",
        "book": "صحيح مسلم",
        "hadith_number": 223,
        "category": "حديث",
        "tags": ["طهارة", "إيمان"]
    },
    {
        "id": 25,
        "text": "من دل على خير فله مثل أجر فاعله",
        "ref": "رواه مسلم",
        "source": "مسلم",
        "book": "صحيح مسلم",
        "hadith_number": 1893,
        "category": "حديث",
        "tags": ["دلالة", "خير", "أجر"]
    },
    {
        "id": 26,
        "text": "الصيام جنة",
        "ref": "متفق عليه",
        "source": "البخاري ومسلم",
        "book": "صحيح البخاري",
        "hadith_number": 1894,
        "category": "حديث",
        "tags": ["صيام", "وقاية"]
    },
    {
        "id": 27,
        "text": "من قام رمضان إيماناً واحتساباً غفر له ما تقدم من ذنبه",
        "ref": "متفق عليه",
        "source": "البخاري ومسلم",
        "book": "صحيح البخاري",
        "hadith_number": 37,
        "category": "حديث",
        "tags": ["رمضان", "قيام", "مغفرة"]
    },
    {
        "id": 28,
        "text": "خيركم من أطعم الطعام ورد السلام",
        "ref": "رواه أحمد",
        "source": "أحمد",
        "book": "مسند أحمد",
        "hadith_number": 23194,
        "category": "حديث",
        "tags": ["طعام", "سلام", "خيرية"]
    },
    {
        "id": 29,
        "text": "لا تحقرن من المعروف شيئاً ولو أن تلقى أخاك بوجه طلق",
        "ref": "رواه مسلم",
        "source": "مسلم",
        "book": "صحيح مسلم",
        "hadith_number": 2626,
        "category": "حديث",
        "tags": ["معروف", "بشاشة", "خلق"]
    },
    {
        "id": 30,
        "text": "من نفس عن مؤمن كربة من كرب الدنيا نفس الله عنه كربة من كرب يوم القيامة",
        "ref": "متفق عليه",
        "source": "البخاري ومسلم",
        "book": "صحيح مسلم",
        "hadith_number": 2699,
        "category": "حديث",
        "tags": ["كربة", "تفريج", "عون"]
    }
]
